# Next.js emits RSC/prefetch payload files (__next*.txt, index.txt,
# _not-found.txt) on every build. This site has a single route and no
# client-side navigation, so nothing consumes them — block direct access
# instead of leaving build internals publicly downloadable.
<FilesMatch "^(__next[._].*\.txt|index\.txt|_not-found\.txt)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Debug/log files should never be written here, but block them defensively
# in case a future debugging session leaves one behind again.
<FilesMatch "\.log$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
