# Utility / debug scripts (never commit)
/opcache-reset.php
/sendy-test.php

# Notes file may contain credentials - never commit
/Info.md

# Secrets
/wp-config.php
/wp-config-local.php
/wp-config-live.php
/.env
/.env.*
/public/.env
/public/.env.*
!.env.example
!/public/.env.example

# Next.js source is tracked (needed for deploy-live.ps1 and future edits);
# only its installed/generated artifacts are not
/next-homepage-src/node_modules/
/next-homepage-src/.next/
/next-homepage-src/out/

# Dependencies
/node_modules/
/public/node_modules/

# Elementor's regenerable CSS cache - churns constantly, no unique content

# Next.js generated output (never commit)
/_next/
/_not-found/
/index.html
/index.txt
/404.html
/_not-found.html
/_not-found.txt
/__next.*.txt
/apple-icon.png
/favicon.png
/icon-dark-32x32.png
/icon-light-32x32.png
/icon.svg

# Build output
/public/.next/
/public/out/
/public/_next/static/*
!/public/_next/static/chunks/
!/public/_next/static/media/
!/public/_next/static/*/
/live-build/

# Vercel / AI tools
/public/.vercel/
/public/.snowflake/
/public/.v0-trash/

