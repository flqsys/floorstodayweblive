# Utility / debug scripts (never commit)
/opcache-reset.php
/sendy-test.php

# Notes file may contain credentials - never commit
/Info.md

# Secrets
/wp-config.php
/wp-config-local.php
/wp-config-live.php
/.env
/.env.*
/public/.env
/public/.env.*
!.env.example
!/public/.env.example

# Next.js source is tracked (needed for deploy-live.ps1 and future edits);
# only its installed/generated artifacts are not
/next-homepage-src/node_modules/
/next-homepage-src/.next/
/next-homepage-src/out/

# Dependencies
/node_modules/
/public/node_modules/

# Next.js generated output (never commit)
/_next/
/_not-found/
/index.html
/index.txt
/404.html
/_not-found.html
/_not-found.txt
/__next.*.txt
/apple-icon.png
/favicon.png
/icon-dark-32x32.png
/icon-light-32x32.png
/icon.svg

# public/ is a pure build artifact now, never tracked: populated locally
# by sync-public.ps1, deployed live only by deploy-live.ps1. It used to
# be partially tracked, which is exactly what let a plain `git pull` on
# the live server overwrite it with the local build (wrong asset paths -
# caused a full homepage outage). Never again - see Info.md.
/public/
/live-build/

# WordPress core - not hand-tracked, updates itself / is only ever
# touched on live. wp-config-sample.php stays as a template reference.
/wp-admin/
/wp-includes/
/wp-*.php
!/wp-config-sample.php
/xmlrpc.php
/license.txt
/readme.html

# wp-content: only track code we actually write and review. Everything
# else (third-party plugins/themes, uploads, languages, cache) is
# WordPress/Elementor content and updates on the live site directly per
# the "no WP changes locally" policy - see Info.md.
/wp-content/*
!/wp-content/mu-plugins
!/wp-content/plugins
!/wp-content/themes
!/wp-content/index.php

/wp-content/mu-plugins/*.bak-*
/wp-content/mu-plugins/floors-leads-export-tool.php

/wp-content/plugins/*
!/wp-content/plugins/floors-itech-crm
!/wp-content/plugins/index.php

/wp-content/themes/*
!/wp-content/themes/FloorsTodayTheme
!/wp-content/themes/index.php

# Vercel / AI tools
/public/.vercel/
/public/.snowflake/
/public/.v0-trash/

# Deployee runtime files
/deployee/storage/*
!/deployee/storage/.gitignore
!/deployee/storage/.htaccess

.htaccess
.htaccess.bak
wp-config.php
wp-config.php.bak
.htaccess-live

# Database dumps & archives
*.sql
*.zip
*.tar
*.tar.gz
*.tgz

# Logs
*.log

# IDE / AI assistant project files (not part of the site)
.vscode/
.idea/
.cursor/
.agents/

# OS
.DS_Store
Thumbs.db

# Local backup copies
*.backup-*
*-backup-*
*.bom-backup-*
*.ctcbackup.*
* copy.css

*.php.*backup-*

# WordPress core auto-generated during updates
/wp-content/upgrade-temp-backup/
